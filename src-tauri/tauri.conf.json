{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "STL Productionz Launcher",
  "version": "1.0.0",
  "identifier": "com.stlproductionz.taverncookbook",
  "build": {
    "beforeDevCommand": "npm run dev:client",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "STL Productionz Launcher",
        "url": "https://the-tavern-cook-book.vercel.app",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "STL Productionz",
    "category": "Productivity",
    "shortDescription": "STL Productionz app launcher",
    "longDescription": "Desktop launcher for The Tavern Cook Book and future STL Productionz tools.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["stl-tavern-cook-book"]
      }
    }
  }
}
